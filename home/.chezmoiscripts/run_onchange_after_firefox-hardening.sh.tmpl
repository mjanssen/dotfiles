#!/usr/bin/env bash

# Hashes below force re-run when source files change:
# user.js:           {{ include "dot_config/firefox-hardening/user.js" | sha256sum }}
# user-overrides.js: {{ include "dot_config/firefox-hardening/user-overrides.js" | sha256sum }}
# userChrome.css:    {{ include "dot_config/firefox-hardening/chrome/userChrome.css" | sha256sum }}
# userContent.css:   {{ include "dot_config/firefox-hardening/chrome/userContent.css" | sha256sum }}
# xulstore.json:     {{ include "dot_config/firefox-hardening/xulstore.json" | sha256sum }}
# containers.json:   {{ include "dot_config/firefox-hardening/containers.json" | sha256sum }}

if pgrep -f '/firefox( |$)' >/dev/null 2>&1; then
  echo "Firefox is running. Quit it before applying (containers.json and prefs are overwritten on shutdown)." >&2
  exit 1
fi

set -euo pipefail

src="$HOME/.config/firefox-hardening"

{{- if eq .chezmoi.os "darwin" }}
firefox_root="$HOME/Library/Application Support/Firefox"
{{- else }}
if [[ -d "$HOME/.var/app/org.mozilla.firefox/.mozilla/firefox" ]]; then
  firefox_root="$HOME/.var/app/org.mozilla.firefox/.mozilla/firefox"
else
  firefox_root="$HOME/.mozilla/firefox"
fi
{{- end }}

profiles_ini="$firefox_root/profiles.ini"
if [[ ! -f "$profiles_ini" ]]; then
  echo "profiles.ini not found at $profiles_ini" >&2
  echo "Launch Firefox once to create the default profile, then re-run: chezmoi apply" >&2
  exit 0
fi

# Locate the profile flagged Default=1
# Firefox 67+ uses [Install...] block's Default=<path> as authoritative.
profile_path=$(awk '
  BEGIN { RS=""; FS="\n" }
  /^\[Install/ {
    for (i=1; i<=NF; i++) {
      if ($i ~ /^Default=/) {
        sub(/^Default=/, "", $i)
        print $i
        exit
      }
    }
  }
' "$profiles_ini")

# Legacy fallback: profile with Default=1
if [[ -z "$profile_path" ]]; then
  profile_path=$(awk '
    BEGIN { RS=""; FS="\n" }
    /^\[Profile/ && /Default=1/ {
      for (i=1; i<=NF; i++) {
        if ($i ~ /^Path=/) { sub(/^Path=/, "", $i); print $i; exit }
      }
    }
  ' "$profiles_ini")
fi

# Last resort: any *.default-release directory
if [[ -z "$profile_path" ]]; then
  profile_path=$(find "$firefox_root" -maxdepth 1 -type d -name '*.default-release' -printf '%f\n' 2>/dev/null | head -1)
fi

if [[ -z "$profile_path" ]]; then
  echo "No default-release profile found in $firefox_root" >&2
  exit 1
fi

profile_dir="$firefox_root/$profile_path"

if [[ -f "$src/xulstore.json" ]]; then
  cp "$src/xulstore.json" "$profile_dir/xulstore.json"
fi

if [[ -f "$src/containers.json" ]]; then
  cp "$src/containers.json" "$profile_dir/containers.json"
fi

{
  cat "$src/user.js"
  if [[ -f "$src/user-overrides.js" ]]; then
    printf '\n/*** User Overrides from user-overrides.js ***/\n'
    cat "$src/user-overrides.js"
  fi
} > "$profile_dir/user.js"

mkdir -p "$profile_dir/chrome"
cp "$src/chrome/userChrome.css"  "$profile_dir/chrome/userChrome.css"
cp "$src/chrome/userContent.css" "$profile_dir/chrome/userContent.css"

rm -f "$profile_dir/containers.json.bak"

echo "Firefox hardening applied to: $profile_dir"
